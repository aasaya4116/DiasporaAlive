{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Location Data Schema",
  "description": "Schema for African diaspora location content data",
  "type": "object",
  "required": ["id", "name", "region", "coordinates", "overview", "culturalElements", "media", "connections"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the location (lowercase, kebab-case)"
    },
    "name": {
      "type": "string",
      "description": "Display name of the location"
    },
    "region": {
      "type": "string",
      "description": "Geographic region (e.g., 'Caribbean', 'South America')"
    },
    "coordinates": {
      "type": "array",
      "description": "Latitude and longitude coordinates [lat, lng]",
      "items": {
        "type": "number"
      },
      "minItems": 2,
      "maxItems": 2
    },
    "overview": {
      "type": "object",
      "required": ["summary", "historicalContext", "populationStats"],
      "properties": {
        "summary": {
          "type": "string",
          "description": "Brief overview of the location's African diaspora significance"
        },
        "historicalContext": {
          "type": "string",
          "description": "Historical background of African presence in the location"
        },
        "populationStats": {
          "type": "object",
          "required": ["population", "percentage", "historicalPeriod", "keyFacts"],
          "properties": {
            "population": {
              "type": "string",
              "description": "Current population of African descent"
            },
            "percentage": {
              "type": "string",
              "description": "Percentage of total population"
            },
            "historicalPeriod": {
              "type": "string",
              "description": "Time period of major African migration/presence"
            },
            "keyFacts": {
              "type": "array",
              "description": "Important facts about the location",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "culturalElements": {
      "type": "object",
      "required": ["music", "food", "religion", "language", "festivals"],
      "properties": {
        "music": {
          "type": "array",
          "items": { "$ref": "#/definitions/culturalElement" }
        },
        "food": {
          "type": "array",
          "items": { "$ref": "#/definitions/culturalElement" }
        },
        "religion": {
          "type": "array",
          "items": { "$ref": "#/definitions/culturalElement" }
        },
        "language": {
          "type": "array",
          "items": { "$ref": "#/definitions/culturalElement" }
        },
        "festivals": {
          "type": "array",
          "items": { "$ref": "#/definitions/culturalElement" }
        }
      }
    },
    "media": {
      "type": "object",
      "required": ["featuredImage", "gallery"],
      "properties": {
        "featuredImage": {
          "$ref": "#/definitions/mediaAsset"
        },
        "gallery": {
          "type": "array",
          "items": { "$ref": "#/definitions/mediaAsset" }
        },
        "audioClips": {
          "type": "array",
          "items": { "$ref": "#/definitions/mediaAsset" }
        }
      }
    },
    "connections": {
      "type": "object",
      "required": ["africanOrigins", "relatedLocations"],
      "properties": {
        "africanOrigins": {
          "type": "array",
          "description": "African countries/regions that influenced this location",
          "items": {
            "type": "string"
          }
        },
        "relatedLocations": {
          "type": "array",
          "description": "Other diaspora locations with similar cultural connections",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "definitions": {
    "culturalElement": {
      "type": "object",
      "required": ["name", "description", "africanRoots", "examples", "significance"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the cultural element"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the cultural element"
        },
        "africanRoots": {
          "type": "string",
          "description": "Explanation of African origins and connections"
        },
        "examples": {
          "type": "array",
          "description": "Specific examples or manifestations",
          "items": {
            "type": "string"
          }
        },
        "significance": {
          "type": "string",
          "description": "Cultural and historical significance"
        }
      }
    },
    "mediaAsset": {
      "type": "object",
      "required": ["id", "url", "alt", "type"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the media asset"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL to the media file"
        },
        "alt": {
          "type": "string",
          "description": "Alternative text for accessibility"
        },
        "caption": {
          "type": "string",
          "description": "Optional caption for the media"
        },
        "type": {
          "type": "string",
          "enum": ["image", "audio", "video"],
          "description": "Type of media asset"
        },
        "thumbnail": {
          "type": "string",
          "format": "uri",
          "description": "Optional thumbnail URL for videos"
        }
      }
    }
  }
}